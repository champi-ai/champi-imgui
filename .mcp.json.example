{
  "mcpServers": {
    "champi-imgui": {
      "command": "uvx",
      "args": [
        "--from",
        "https://github.com/champi-ai/champi-imgui/releases/download/v1.19.3/champi_imgui-1.19.3-py3-none-any.whl",
        "champi-imgui",
        "serve"
      ],
      "env": {
        "WAYLAND_DISPLAY": "wayland-0",
        "XDG_RUNTIME_DIR": "/run/user/1000"
      }
    }
  }
}
